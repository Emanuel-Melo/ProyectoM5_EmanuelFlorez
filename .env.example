# ==========================================
# FIREBASE WEB (Frontend - Variables Públicas)
# ==========================================
# Obtener valores de Firebase Console > Project Settings > Your apps > Web

VITE_FIREBASE_API_KEY=AIzaSyD...
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456ghi789

# ==========================================
# BACKEND - API Local (Desarrollo)
# ==========================================
# Estos valores son para npm run dev:api

SERVICE_ACCOUNT_KEY_PATH=./serviceAccountKey.json
# Alternativa: GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

DEV_API_PORT=5174
VITE_API_BASE_URL=http://localhost:5174
VITE_S3_UPLOAD_API_URL=http://localhost:5174

# ==========================================
# AWS S3 (Opcional - Para uploads de imágenes)
# ==========================================
# Obtener credenciales de AWS IAM Console
# Política mínima requerida: s3:PutObject, s3:GetObject en el bucket

AWS_S3_BUCKET_NAME=mi-bucket-ecommerce
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEM...

# Opcional: Credenciales temporales
# AWS_SESSION_TOKEN=AQoDYXdzEI...

# Opcional: Tiempo de expiración para URLs presignadas (en segundos)
# AWS_UPLOAD_EXPIRES_SECONDS=900

# ==========================================
# NOTAS DE SEGURIDAD
# ==========================================
# 1. Este archivo (.env.example) es público - NO incluye valores reales
# 2. El archivo .env es PRIVADO - debe estar en .gitignore
# 3. NUNCA commitear credenciales de AWS o Firebase Admin
# 4. Firebase Web keys son públicas pero no exponerlas innecesariamente
# 5. En Vercel, las variables se agregan en Project Settings > Environment Variables
# 6. Las variables VITE_* están disponibles en frontend
# 7. Las variables sin VITE_ son solo para backend (Vercel Functions)

# ==========================================
# INSTRUCCIONES DE SETUP
# ==========================================
# 1. Copiar este archivo: cp .env.example .env
# 2. Rellenar .env con tus valores reales
# 3. Nunca hacer git add .env
# 4. Para Vercel: Agregar manualmente en Dashboard (no syncear desde .env)